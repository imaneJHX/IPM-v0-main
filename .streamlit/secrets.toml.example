# Streamlit Community Cloud setup:
# 1. Open Manage app > Settings > Secrets.
# 2. Paste the IPM_API_URL value below with your deployed FastAPI backend URL.
# 3. Keep the real .streamlit/secrets.toml file out of Git.
#
# Local development can use either .env or .streamlit/secrets.toml.

IPM_API_URL="https://your-backend-url.com"
