{
  "version": 2,
  "functions": {
    "api/index.py": {
      "excludeFiles": "{streamlit_app.py,streamlit-*.log,ai-cv-sorter.html,__pycache__/**,.venv-backend/**,.dist/**,backend/ipm-local.db,backend/tests/**,frontend/**}"
    }
  },
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/health",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
