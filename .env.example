# === LLM Provider ===
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here

# Azure OpenAI (v1 migration — uncomment and set LLM_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# === Embedding Provider ===
EMBEDDING_PROVIDER=local
# OPENAI_API_KEY=your_openai_key_here  # for v1 migration

# === Langfuse ===
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# === Database ===
DATABASE_URL=postgresql+asyncpg://ipm:ipm@postgres:5432/ipm

# === ChromaDB ===
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# === MinIO ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# === Tech Signals (Tavily — free tier: 1,000 credits) ===
# Basic search only = 1 credit per unique need (cached forever after first call)
TAVILY_API_KEY=           # Required to enable Tech Signals
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic
